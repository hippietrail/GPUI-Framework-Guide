# Maintainer: Rudrabhoj Bhati <hello@rudrabhoj.com>
#
# Binary AUR package. It downloads the prebuilt x86_64 Linux archive attached
# to the matching GitHub release. Bump pkgver and refresh the sha256sums with
# `updpkgsums` for each release.
pkgname=numnum-bin
_pkgname=numnum
pkgver=0.2.0
pkgrel=1
pkgdesc="A text editor that does math - units, currencies and percentages in plain language"
arch=('x86_64')
url="https://github.com/rudrabhoj/numnum"
license=('GPL-2.0-only')
provides=('numnum')
conflicts=('numnum')
options=('!strip')
source=("$_pkgname-$pkgver.tar.xz::https://github.com/rudrabhoj/numnum/releases/download/v$pkgver/numnum-x86_64-unknown-linux-gnu.tar.xz"
        "numnum.desktop::https://raw.githubusercontent.com/rudrabhoj/numnum/v$pkgver/packaging/numnum.desktop"
        "numnum.svg::https://raw.githubusercontent.com/rudrabhoj/numnum/v$pkgver/assets/icons/numnum.svg")
sha256sums=('SKIP'
            'SKIP'
            'SKIP')

package() {
    # cargo-dist archive layout can place the binary at the root or in a
    # versioned subdir; locate it either way.
    local bin
    bin=$(find "$srcdir" -type f -name numnum -perm -u+x | head -1)
    install -Dm755 "$bin" "$pkgdir/usr/bin/numnum"
    install -Dm644 "$srcdir/numnum.desktop" "$pkgdir/usr/share/applications/numnum.desktop"
    install -Dm644 "$srcdir/numnum.svg" "$pkgdir/usr/share/icons/hicolor/scalable/apps/numnum.svg"
}
