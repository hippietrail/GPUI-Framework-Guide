name: numnum
version: "@VERSION@"
origin: math/numnum
comment: "A text editor that does math"
desc: <<EOD
NumNum is a notebook-style calculator. Type expressions in plain language
- units, currencies and percentages - and results appear as you type,
lined up with what you wrote.
EOD
maintainer: hello@rudrabhoj.com
www: https://github.com/rudrabhoj/numnum
prefix: /usr/local
licenselogic: single
licenses: [GPLv2]
categories: [math]
