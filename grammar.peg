// =============================================================================
// numnum — Actionable PEG Grammar (pest syntax)
//
// Executable grammar specification for a high-performance notebook calculator.
//
// Architecture for JIT:
//   1. LEXER  — single-pass tokenizer, units/currencies via phf hashmap
//   2. PARSER — Pratt parser using binding powers below
//   3. IR     — flat bytecode (stack machine), no heap alloc per-eval
//   4. JIT    — cranelift or copy-and-patch from IR to native code
//
// Units and currencies are NOT grammar rules — they are data tables
// loaded at init and queried during lexing. See data/*.txt (168 currencies).
//
// PARSER BEHAVIOR:
//   - Trailing tokens after a complete expression are rejected (parse error)
//   - Mixed currency arithmetic converts RHS to LHS for ALL operators
//   - Same-unit/currency division returns a dimensionless result
//   - Currency symbols work in BOTH prefix AND suffix: $10 and 10$
//   - Currency codes work in BOTH prefix AND suffix: INR 50 and 50 INR
//   - Display shorthands recognized as input: Dh (AED), SFr. (CHF),
//     R$ (BRL), HK$ (HKD), S$ (SGD), SR (SAR), NIS (ILS), NT$ (TWD)
//   - Inches display as "inches" not "in" (avoids conflict with conversion)
// =============================================================================


// =============================================================================
// DOCUMENT STRUCTURE
// =============================================================================

document = { SOI ~ line ~ (NEWLINE ~ line)* ~ EOI }

line = {
    comment_line
  | header_line
  | statement_line
  | blank_line
}

blank_line   = { "" }
comment_line = @{ PEEK_WS* ~ "//" ~ (!NEWLINE ~ ANY)* }
header_line  = @{ PEEK_WS* ~ "#" ~ (!NEWLINE ~ ANY)* }

statement_line = {
    label? ~ statement_body
}


// =============================================================================
// LABELS AND INLINE COMMENTS
// =============================================================================

label = @{ identifier ~ ":" ~ " " }

inline_comment = @{ "\"" ~ (!"\"" ~ ANY)* ~ "\"" }


// =============================================================================
// STATEMENT BODY
// =============================================================================

statement_body = {
    assignment
  | compound_assignment
  | aggregation
  | expression
}

assignment = { identifier ~ "=" ~ expression }

compound_assignment = { identifier ~ compound_op ~ expression }
compound_op = { "+=" | "-=" | "*=" | "/=" }

aggregation = {
    "sum" | "total" | "average" | "avg" | "prev"
}


// =============================================================================
// EXPRESSIONS — PRATT PARSER BINDING POWERS
//
// BP TABLE (higher = binds tighter):
//   ( 1, 2)  in, to, as, into             left       conversion
//   ( 3, 4)  N% (inline percent +/-)      left       pct_adjust
//   ( 5, 6)  &, |, xor                    left       bitwise_op
//   ( 7, 8)  <<, >>                        left       shift_op
//   ( 9,10)  +, -, plus, minus, etc       left       binary_op
//   (11,12)  *, /, mod, times, etc        left       binary_op
//   (13,14)  ^                            LEFT(!)    binary_op
//   (—, 15)  - (unary prefix)             prefix     unary_op
//   (—, 17)  sqrt, sin, abs, etc          prefix     func_call
//   (—, 19)  %, of, on, off               prefix     percent_op
//
// NOTE: reference calculator ^ is LEFT-associative: 2^3^2 = (2^3)^2 = 64
// =============================================================================

expression = { conversion_expr }

conversion_expr = {
    as_a_percent_expr ~ (conversion_op ~ target)?
}

// "$50 as a % of $100" — infix, lower precedence than arithmetic
as_a_percent_expr = {
    percent_adjust_expr ~ (as_a_pct_keyword ~ percent_adjust_expr)?
}

percent_adjust_expr = {
    bitwise_expr ~ ((add_op | sub_op) ~ percent_literal)*
}

bitwise_expr = {
    shift_expr ~ (bitwise_op ~ shift_expr)*
}

shift_expr = {
    additive_expr ~ (shift_op ~ additive_expr)*
}

additive_expr = {
    multiplicative_expr ~ (additive_op ~ multiplicative_expr)*
}

multiplicative_expr = {
    power_expr ~ (multiplicative_op ~ power_expr)*
}

power_expr = {
    unary_expr ~ ("^" ~ unary_expr)*
}

unary_expr = {
    "-" ~ atom
  | atom
}

atom = {
    "(" ~ expression ~ ")"
  | prefix_percent_expr
  | function_call
  | datetime_expr
  | number_with_unit
  | scaled_number
  | number
  | variable
}


// =============================================================================
// OPERATORS
//
// Word-form operators (plus, times, etc.) are resolved by the lexer to the
// same token as their symbol counterpart. Grammar only shows symbols.
// =============================================================================

additive_op = {
    "+" | "-"
}

multiplicative_op = {
    "*" | "/" | "\u{00D7}" | "\u{00F7}"
}

add_op = { "+" }
sub_op = { "-" }

bitwise_op = { "&" | "|" | "xor" }
shift_op   = { "<<" | ">>" }

conversion_op = { "in" | "to" | "as" | "into" }

target = {
    repr_keyword
  | unit_identifier
}

repr_keyword = {
    "hex" | "binary" | "bin" | "octal" | "oct"
  | "decimal" | "dec" | "scientific" | "sci"
  | "exp" | "exponent" | "exponential"
}


// =============================================================================
// PERCENT EXPRESSIONS
// =============================================================================

// Prefix percent forms (no left recursion — percent_literal starts with number)
prefix_percent_expr = {
    reverse_percent_expr
  | percent_of_expr
  | percent_on_off_expr
  | bare_percent
}

percent_of_expr = { percent_literal ~ ("of" | "from") ~ atom }

percent_on_off_expr = { percent_literal ~ ("on" | "off") ~ atom }

reverse_percent_expr = {
    percent_literal ~ reverse_pct_keyword ~ atom
}
reverse_pct_keyword = {
    "of what is" | "on what is" | "off what is"
}

percent_literal = { number ~ percent_symbol }
percent_symbol  = { "%" | "percent" | "percents" | "pct" | "pct." }

bare_percent = { percent_literal }

// "as a % of" forms are INFIX — handled post-parse or in Pratt parser.
// In the PEG, they attach as a suffix to a primary expression:
//   expression ~ as_a_pct_keyword ~ expression
// This is encoded in the expression precedence chain, not in atom.
as_a_pct_keyword = {
    "as a % of" | "as a percent of"
  | "as a % on" | "as a percent on"
  | "as a % increase of" | "as a percent increase of"
  | "as a % off" | "as a percent off"
  | "as a % decrease of" | "as a percent decrease of"
}


// =============================================================================
// FUNCTION CALLS
//
// Two call styles:
//   sqrt(16)       — parenthesized (any expression)
//   sqrt 16        — space-separated (single atom)
// =============================================================================

function_call = {
    function_name ~ "(" ~ expression ~ ")"
  | function_name ~ atom
}

function_name = {
    "square root" | "sqrt"
  | "cubic root" | "cube root" | "cubed root" | "cbrt"
  | "abs"
  | "round" | "ceil" | "floor"
  | "log" | "ln"
  | "fact"
  | "arcsin" | "arccos" | "arctan"
  | "asin" | "acos" | "atan"
  | "sinh" | "cosh" | "tanh"
  | "sin" | "cos" | "tan"
}


// =============================================================================
// NUMBERS
// =============================================================================

number = @{
    hex_number
  | binary_number
  | octal_number
  | decimal_number
}

decimal_number = @{
    "-"?
    ~ (
        ASCII_DIGIT{1,3} ~ ("," ~ ASCII_DIGIT{3})+ ~ ("." ~ ASCII_DIGIT+)?
      | ASCII_DIGIT+ ~ ("." ~ ASCII_DIGIT+)?
      | "." ~ ASCII_DIGIT+
    )
    ~ (("e" | "E") ~ ("+" | "-")? ~ ASCII_DIGIT+)?
}

hex_number    = @{ "0" ~ ("x" | "X") ~ ASCII_HEX_DIGIT+ }
binary_number = @{ "0b" ~ ('0'..'1')+ }
octal_number  = @{ "0" ~ ("o" | "O") ~ ('0'..'7')+ }

scaled_number = { number ~ scale ~ unit_identifier? }

scale = {
    "thousand" | "Thousand" | "thousands" | "Thousands" | "th."
  | "million"  | "Million"  | "millions"  | "Millions"
  | "billion" | "Billion" | "milliard" | "Milliard"
  | "billions" | "Billions" | "milliards" | "Milliards"
  | "trillion" | "Trillion" | "trillions" | "Trillions"
  | "quadrillion" | "Quadrillion" | "quadrillions" | "Quadrillions"
  | "quintillion" | "Quintillion" | "quintillions" | "Quintillions"
  | "sextillion" | "Sextillion" | "sextillions" | "Sextillions"
  | "septillion" | "Septillion" | "septillions" | "Septillions"
  | "th" | "k" | "M"
}


// =============================================================================
// UNITS AND CURRENCIES — DATA-DRIVEN
//
// unit_identifier is a catch-all for any word(s) that the lexer resolves
// against the unit/currency hash tables. In the PEG it's just an identifier.
// The LEXER decides if "km", "USD", "euro" etc. are units or variables.
// =============================================================================

number_with_unit = {
    currency_symbol ~ number                    // $10, €50
  | number ~ currency_symbol                    // 10$, 50€
  | compound_currency_symbol ~ number           // R$10, HK$50, S$30, NT$100
  | number ~ compound_currency_symbol           // 10R$, 50HK$
  | currency_code ~ number                      // INR 50, USD 100
  | number ~ currency_code                      // 50 INR, 100 USD
  | number ~ unit_identifier
}

// Compound currency symbols that end with $
compound_currency_symbol = { ("R" | "HK" | "S" | "NT") ~ "$" }

// ISO 4217 currency codes (data-driven, see data/currencies.txt — 168 total)
currency_code = @{ ASCII_ALPHA{2,3} }

// Currency symbols are grammar-level (prefix/suffix punctuation)
currency_symbol = {
    "$" | "\u{20AC}" | "\u{00A3}" | "\u{00A5}"
  | "\u{20BD}" | "\u{20AA}" | "\u{20B9}" | "\u{20A9}"
  | "\u{20B4}" | "\u{20BF}" | "\u{20BA}" | "\u{0E3F}"
  | "\u{20B1}" | "\u{20A6}" | "\u{20AB}" | "\u{20A8}"
  | "\u{09F3}" | "\u{20B8}" | "\u{20BC}" | "\u{20BE}"
  | "\u{058F}" | "\u{17DB}" | "\u{20AD}" | "\u{20AE}"
  | "\u{20A1}" | "\u{20B2}" | "\u{0192}"
}

// Catch-all: any word the lexer will resolve to a unit, currency code, etc.
unit_identifier = @{ ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_" | "." | " " | "/" | "\u{00B2}" | "\u{00B3}")* }


// =============================================================================
// DATE AND TIME
// =============================================================================

datetime_expr = {
    datetime_keyword ~ additive_op ~ number ~ time_unit
  | datetime_keyword ~ conversion_op ~ timezone
  | datetime_keyword
  | time_literal ~ conversion_op ~ timezone
  | time_literal
}

datetime_keyword = { "now" | "time" | "today" | "tomorrow" | "yesterday" }

time_literal = @{
    ASCII_DIGIT{1,2} ~ ":" ~ ASCII_DIGIT{2} ~ (":" ~ ASCII_DIGIT{2})?
    ~ (" "+ ~ ("am" | "pm" | "AM" | "PM"))?
}

time_unit = {
    "second" | "seconds" | "sec"
  | "minute" | "minutes" | "min"
  | "hour"   | "hours"   | "hr"
  | "week"   | "weeks"
  | "month"  | "months"  | "mon"
  | "year"   | "years"   | "yr"
  | "day"    | "days"
  | "s" | "h" | "d" | "w" | "y"
}

timezone = @{ (ASCII_ALPHA | "/" | "_")+ }


// =============================================================================
// VARIABLES AND IDENTIFIERS
// =============================================================================

variable = @{ ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_")* }

identifier = @{ ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_")* }


// =============================================================================
// WHITESPACE
// =============================================================================

WHITESPACE = _{ " " | "\t" }
NEWLINE    = _{ "\r\n" | "\n" | "\r" }
PEEK_WS    = { " " | "\t" }
